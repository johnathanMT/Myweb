# ============================================================================
#  Site configuration — copy to ".env" for local dev, or set these in CI
#  (GitHub Actions) for production. Vite only exposes vars prefixed with VITE_.
#  These are baked in at BUILD time, so rebuild after changing them.
#
#  To migrate the whole site to a new domain, you normally change just two:
#    VITE_SITE_URL  and  VITE_BASE
# ============================================================================

# Canonical absolute origin (used for SEO/OG/canonical links only).
VITE_SITE_URL=https://myothant.dev

# Path the site is served from:
#   /Myweb/   → GitHub Pages project site (johnathanmt.github.io/Myweb/)
#   /         → custom apex domain (myothant.dev)
VITE_BASE=/

# Backend API origin.
VITE_API_URL=https://myweb-zqv1.onrender.com

# Public contact email.
VITE_CONTACT_EMAIL=ai@myothant.dev

# LINE / AI-bot chat link.
VITE_LINE_URL=https://lin.ee/s72ayHD

# External "Bean Boutique" demo project (separate repo).
VITE_COFFEE_URL=https://johnathanmt.github.io/bean-boutique-coffee-shop/

# Immersive 3D experience (separate WebGL build on its own subdomain). The
# Gateway's "Immersive 3D Mode" button links here. Falls back to the default
# below if unset.
VITE_IMMERSIVE_URL=https://immersive.myothant.dev

# Explore section — cinematic hover stills via Unsplash (royalty-free). OPTIONAL:
# without it, cards use a themed gradient. Get a free key at unsplash.com/developers
# (Access Key). Leave blank to disable remote fetching.
# VITE_UNSPLASH_KEY=your_unsplash_access_key

# Build mode (single repo, two Vercel deployments):
#   immersive → heavy WebGL build (set ONLY on the immersive.myothant.dev project)
#   unset     → lightweight Gateway Hub (the default for myothant.dev)
# VITE_APP_MODE=immersive
